      "--max-connection-per-server=4",
      "-x 6 -s 24",
      "--min-split-size=1M"
    ],
    "args": [
      {
        "matcher": {
          "type": "url",
          "pattern": "^https?://ddad\\.artifactory\\.cc\\.bmwgroup\\.net"
        },
        "args": [
          "--username=hankguo --password=123456"
        ]
      }
    ]
  }
}
